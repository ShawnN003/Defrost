{
  "name": "sdev-defrost-real",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev": "vite",
    "dev:backend": "nodemon backend/index.js",
    "test": "npm run test:frontend && npm run test:integration",
    "test:e2e": "playwright test",
    "test:integration": "npm --prefix backend run test",
